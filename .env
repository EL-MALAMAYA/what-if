GMI_ENDPOINT_URL=https://api.gmi-serving.com/v1
# Model id from GET https://api.gmi-serving.com/v1/models (must match your deployment)
GMI_MODEL=deepseek-ai/DeepSeek-R1-0528
# Longer timeout (seconds) + retries help slow reasoning models and transient 523/502 from the gateway
GMI_TIMEOUT=300
GMI_MAX_RETRIES=8
# Keep responses compact to reduce long-running websocket sessions
GMI_MAX_TOKENS=700
GMI_TEMPERATURE=0.2
# Optional: set to true only if your model supports OpenAI-style json_object responses (often not DeepSeek)
# GMI_USE_JSON_RESPONSE_FORMAT=false

# Optional Claude provider settings (used when selecting "Claude API" in app toggle)
# CLAUDE_API_KEY=your_claude_api_key_here
# CLAUDE_MODEL=claude-3-5-sonnet-20241022
